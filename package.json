{
  "name": "remotedeskpbx",
  "version": "1.0.0",
  "description": "MVP инструмента удалённого доступа к экрану",
  "main": "dist/main/index.js",
  "scripts": {
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "webpack --mode production",
    "build": "npm run build:main && npm run build:renderer",
    "start": "npm run build && electron .",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "webpack --mode development --watch",
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "pack": "npm run build && electron-builder --win portable",
    "dist": "npm run build && electron-builder --win portable"
  },
  "dependencies": {
    "@fastify/websocket": "^11.0.1",
    "fastify": "^5.2.1",
    "ioredis": "^5.4.2",
    "peerjs": "^1.5.5",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.5.14",
    "concurrently": "^9.1.2",
    "css-loader": "^7.1.2",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "html-webpack-plugin": "^5.6.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.2",
    "typescript": "^5.7.3",
    "webpack": "^5.97.1",
    "webpack-cli": "^6.0.1"
  }
}
